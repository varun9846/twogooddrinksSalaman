{
  "output": {
    "filePath": "repomix-output.md",
    "style": "markdown",
    "removeComments": true,
    "removeEmptyLines": true,
    "topFilesLength": 5
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "**/node_modules/**",
      "**/.next/**",
      "**/out/**",
      "**/public/**",
      "**/*.log",
      "package-lock.json",
      "yarn.lock",
      "pnpm-lock.yaml",
      "**/tsconfig.tsbuildinfo",
      "**/next-env.d.ts",
      ".eslintrc.json",
      ".prettierrc",
      "postcss.config.mjs",
      "tailwind.config.ts"
    ]
  },
  "include": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "types/**/*.{ts,tsx}",
    "services/**/*.{ts,tsx}"
  ]
}