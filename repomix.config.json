{
  "output": {
    "filePath": "repomix-output.md",
    "style": "markdown",
    "removeComments": true,
    "removeEmptyLines": true,
    "topFilesLength": 5
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "**/node_modules/**",
      "**/.next/**",
      "**/out/**",
      "**/*.log",
      "package-lock.json",
      "yarn.lock",
      "pnpm-lock.yaml",
      "**/tsconfig.tsbuildinfo",
      "**/next-env.d.ts",
      ".eslintrc.json",
      ".prettierrc",
      "postcss.config.mjs",
      "tailwind.config.ts"
    ]
  },
  "include": [
    "src/app/**/*.{ts,tsx}",
    "src/components/**/*.{ts,tsx}",
    "src/lib/**/*.{ts,tsx}",
    "src/store/**/*.{ts,tsx}",
    "src/types/**/*.{ts,tsx}",
    "src/auth.ts",
    "src/middleware.ts",
    "src/styles/**/*.css",
    "prisma/**/*.prisma",
    "sql/**/*.sql",
    "README.md",
    "architecture.md",
    "AGENTS.md",
    "instructions.prompt.md.md",
    "package.json",
    "next.config.ts",
    "tsconfig.json",
    "eslint.config.mjs"
  ]
}